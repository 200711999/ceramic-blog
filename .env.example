# ============================================
# 环境变量配置示例
# 复制本文件为 .env 后填入真实值，.env 不会被提交到 Git
# ============================================

# --------------------------------------------
# Django 安全配置
# --------------------------------------------
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --------------------------------------------
# 数据库配置（MySQL）
# --------------------------------------------
DB_NAME=myblog
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# --------------------------------------------
# AI 写作辅助配置 (SiliconFlow)
# 获取地址：https://siliconflow.cn/
# --------------------------------------------
AI_API_KEY=your-siliconflow-api-key
AI_BASE_URL=https://api.siliconflow.cn/v1
AI_MODEL=deepseek-ai/DeepSeek-V3
AI_TIMEOUT=90

# --------------------------------------------
# AI 备用配置 (DeepSeek 官方)
# 获取地址：https://platform.deepseek.com/
# --------------------------------------------
AI_API_KEY_BACKUP=your-deepseek-api-key
AI_BASE_URL_BACKUP=https://api.deepseek.com
AI_MODEL_BACKUP=deepseek-chat
